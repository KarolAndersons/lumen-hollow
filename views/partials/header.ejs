<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Lumen Hollow is a nocturnal wildlife reserve in the United Kingdom, open every day from 9.00 am to 6.00 pm. Five habitats, twenty exhibits, year-round events.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,700&family=Inter:wght@300;400;500;600&display=swap">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg">
</head>
<body>
  <a class="skip-link" href="#main">Skip to main content</a>
  <header class="site-header">
    <div class="site-header__inner">
      <a class="brand" href="/" aria-label="Lumen Hollow home">
        <svg class="brand__mark" viewBox="0 0 40 40" aria-hidden="true" focusable="false">
          <circle cx="20" cy="20" r="14" fill="none" stroke="currentColor" stroke-width="1.5"></circle>
          <path d="M 12 18 A 9 9 0 0 0 28 22" fill="none" stroke="currentColor" stroke-width="1.5"></path>
          <circle cx="20" cy="14" r="1.4" fill="currentColor"></circle>
        </svg>
        <span class="brand__text">
          <span class="brand__name">Lumen Hollow</span>
          <span class="brand__tagline">Nightfall Wildlife Reserve</span>
        </span>
      </a>

      <nav class="site-nav" aria-label="Primary">
        <button class="site-nav__toggle" type="button" aria-expanded="false" aria-controls="site-nav-list">
          <span class="visually-hidden">Open menu</span>
          <span class="site-nav__bars" aria-hidden="true"></span>
        </button>
        <ul class="site-nav__list" id="site-nav-list">
          <li><a href="/"<% if (currentPath === '/') { %> aria-current="page"<% } %>>Map</a></li>
          <li><a href="/habitats"<% if (currentPath.startsWith('/habitats')) { %> aria-current="page"<% } %>>Habitats</a></li>
          <li><a href="/events"<% if (currentPath.startsWith('/events')) { %> aria-current="page"<% } %>>Events</a></li>
          <li><a href="/activity"<% if (currentPath.startsWith('/activity')) { %> aria-current="page"<% } %>>Activity</a></li>
          <li><a href="/faq"<% if (currentPath.startsWith('/faq')) { %> aria-current="page"<% } %>>FAQ</a></li>
          <li><a href="/contact"<% if (currentPath.startsWith('/contact')) { %> aria-current="page"<% } %>>Contact</a></li>
        </ul>
      </nav>

      <form class="site-search" action="/search" method="get" role="search">
        <label for="site-search-input" class="visually-hidden">Search the park</label>
        <input
          type="search"
          id="site-search-input"
          name="q"
          placeholder="Search the park…"
          autocomplete="off"
          aria-describedby="site-search-status">
        <button type="submit" aria-label="Search">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" width="18" height="18">
            <circle cx="11" cy="11" r="6" fill="none" stroke="currentColor" stroke-width="1.6"></circle>
            <line x1="15.5" y1="15.5" x2="20" y2="20" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></line>
          </svg>
        </button>
        <div class="site-search__suggestions" id="site-search-status" role="status" aria-live="polite"></div>
      </form>
    </div>
    <p class="opening-banner" role="note"><%= openingHours %></p>
  </header>
  <main id="main">
